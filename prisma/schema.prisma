generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum FeatureStatus {
  PENDING
  OPEN
  COMMITTED
  IN_PROGRESS
  SHIPPED
  REJECTED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  role             Role             @default(USER)
  monthlyAllowance Int              @default(10)
  currentBalance   Int              @default(10)
  companyName      String?
  passwordHash     String           @default("")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  featureRequests  FeatureRequest[]
  contributions    Contribution[]
  creditPurchases  CreditPurchase[]
}

model ProductTag {
  id          String           @id @default(cuid())
  value       String           @unique
  label       String
  color       String
  description String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  features    FeatureRequest[]
}

model FeatureRequest {
  id              String        @id @default(cuid())
  title           String
  description     String        @db.Text
  productTagId    String
  productTag      ProductTag    @relation(fields: [productTagId], references: [id])
  status          FeatureStatus @default(PENDING)
  caratCost       Int?
  totalFunded     Int           @default(0)
  rejectionReason String?
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  contributions   Contribution[]
}

model Contribution {
  id        String         @id @default(cuid())
  userId    String
  featureId String
  amount    Int
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  feature   FeatureRequest @relation(fields: [featureId], references: [id])
}

model CreditPurchase {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  packageId       String
  creditsGranted  Int
  amountCents     Int
  stripeSessionId  String         @unique
  status           PurchaseStatus @default(PENDING)
  remainingCredits Int?
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
